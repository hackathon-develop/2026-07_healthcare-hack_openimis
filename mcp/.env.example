# Copy to .env and fill in for local testing. On Cloud Run, set these as
# environment variables / secrets instead of shipping a .env file.

OPENIMIS_DB_HOST=your-db-host
OPENIMIS_DB_PORT=5432
OPENIMIS_DB_NAME=openimis
OPENIMIS_DB_USER=openimis_readonly
OPENIMIS_DB_PASSWORD=changeme

# "prefer" is fine for local/private-network Postgres. If the database is
# outside Google Cloud and reached over the public internet, set this to
# "require" (or "verify-full" with a root cert configured) instead.
OPENIMIS_DB_SSLMODE=prefer

# --- Claim creation only (separate connection, not the DB) ---
# openIMIS's own GraphQL endpoint, e.g. https://your-openimis-host/api/graphql
OPENIMIS_GRAPHQL_URL=

# A DEDICATED openIMIS technical user (or interactive user) scoped to ONLY
# the create_claim and submit_claim rights (111002, 111007 by default —
# confirm in your instance's role admin). Never use an admin account here.
OPENIMIS_TECH_USER=
OPENIMIS_TECH_PASSWORD=
